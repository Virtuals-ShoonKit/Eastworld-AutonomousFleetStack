<?xml version="1.0"?>
<!--
  Scout Mini URDF for Nav2 integration.

  Frames produced (base_link is root; EKF publishes odom->base_link):
    base_link  (chassis centre)
    ├── base_footprint  (ground contact, z = -0.178 m below base_link)
    ├── front_left_wheel_link   (continuous joint)
    ├── front_right_wheel_link  (continuous joint)
    ├── rear_left_wheel_link    (continuous joint)
    ├── rear_right_wheel_link   (continuous joint)
    └── lidar_mount_link  (z = +0.4 m above base_link, 0 deg pitch)
        ├── imu_link      (Livox MID360 built-in IMU, co-located)
        ├── livox_frame   (LiDAR optical frame)
        └── zedm_camera_link  (ZED Mini left camera, y=+3.5cm left, z=-2cm below)

  Dimensions from Agilex Scout Mini datasheet / upstream scout_description:
    Length    0.627 m
    Width     0.550 m  (including wheels)
    Height    0.250 m  (body only)
    Track     0.490 m  (wheel centre-to-centre)
    Wheelbase 0.452 m
    Wheel radius  0.0875 m
    Wheel width   0.0852 m
    Mass ~23 kg

  LiDAR is mounted flat (0° pitch).
  Measured offset from base_link: x=+0.255 m (forward), z=+0.40 m (up)
-->
<robot name="scout_mini" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="M_PI"         value="3.14159265359"/>
  <xacro:property name="body_length"  value="0.627"/>
  <xacro:property name="body_width"   value="0.400"/>
  <xacro:property name="body_height"  value="0.250"/>
  <xacro:property name="body_mass"    value="23.0"/>

  <xacro:property name="wheelbase"    value="0.452"/>
  <xacro:property name="track"        value="0.490"/>
  <xacro:property name="wheel_radius" value="0.0875"/>
  <xacro:property name="wheel_width"  value="0.0852"/>
  <xacro:property name="wheel_mass"   value="1.5"/>

  <!-- base_link is wheel_radius + |wheel_vertical_offset| above ground = 0.0875 + 0.0905 -->
  <xacro:property name="base_link_z"  value="0.178"/>

  <!-- LiDAR mount: xyz offset from base_link. Sensor is mounted flat (0° pitch). -->
  <!-- Measured: 25.5 cm forward, 40 cm above base_link -->
  <xacro:property name="lidar_x"      value="0.255"/>
  <xacro:property name="lidar_y"      value="0.0"/>
  <xacro:property name="lidar_z"      value="0.40"/>
  <xacro:property name="sensor_pitch_deg" value="0.0"/>
  <xacro:property name="sensor_pitch_rad" value="${sensor_pitch_deg * M_PI / 180.0}"/>

  <!-- wheel centre sits 0.0905 m below base_link origin (matches upstream datasheet) -->
  <xacro:property name="wheel_vertical_offset" value="-0.0905"/>

  <!-- ===== Wheel macro ===== -->
  <xacro:macro name="scout_mini_wheel" params="name x_offset y_offset">
    <link name="${name}_wheel_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.006"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x_offset} ${y_offset} ${wheel_vertical_offset}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ===== base_link (root frame — EKF publishes odom→base_link) ===== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="${body_mass}"/>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="0.8"/>
    </inertial>
  </link>

  <!-- base_footprint: ground-plane projection of base_link -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 -${base_link_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===== Wheels ===== -->
  <xacro:scout_mini_wheel name="front_left"  x_offset="${wheelbase/2}"  y_offset="${track/2}"/>
  <xacro:scout_mini_wheel name="front_right" x_offset="${wheelbase/2}"  y_offset="${-track/2}"/>
  <xacro:scout_mini_wheel name="rear_left"   x_offset="${-wheelbase/2}" y_offset="${track/2}"/>
  <xacro:scout_mini_wheel name="rear_right"  x_offset="${-wheelbase/2}" y_offset="${-track/2}"/>

  <!-- ===== LiDAR / IMU mount ===== -->
  <link name="lidar_mount_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_mount_link"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 ${sensor_pitch_rad} 0"/>
  </joint>

  <!-- imu_link: Livox MID360 built-in IMU, co-located with LiDAR -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="lidar_mount_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- livox_frame: LiDAR optical frame (used by livox_ros_driver2) -->
  <link name="livox_frame"/>
  <joint name="livox_frame_joint" type="fixed">
    <parent link="lidar_mount_link"/>
    <child link="livox_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===== ZED Mini stereo camera ===== -->
  <!-- Mounted below lidar, left camera 3.5 cm left of lidar centre, 2 cm below.
       ZED wrapper (publish_urdf:true) adds child frames from here:
         zedm_left_camera_frame, zedm_left_camera_optical_frame, etc. -->
  <link name="zedm_camera_link"/>
  <joint name="zed_mount_joint" type="fixed">
    <parent link="lidar_mount_link"/>
    <child link="zedm_camera_link"/>
    <origin xyz="0.0 0.035 -0.02" rpy="0 0 0"/>
  </joint>

</robot>
